# Fast AWS database path for the H0 deployment.
DYNAMODB_TABLE=h0-archon-reports
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional Aurora PostgreSQL fallback. Leave unset when using DynamoDB.
DATABASE_URL=

# Aurora normally requires SSL. Set to disable only for local PostgreSQL.
PGSSLMODE=require

# No third-party LLM key is required for the public H0 demo.
