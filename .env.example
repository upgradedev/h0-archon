# AWS database path for the H0 deployment.
DYNAMODB_TABLE=h0-archon-reports
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Leave the AWS vars unset to run in the in-process demo store.
# No third-party LLM key is required for the public H0 demo.

# --- GitHub OAuth (OPTIONAL) ------------------------------------------------
# "Sign in with GitHub" gating is OPT-IN. Leave these UNSET and the app stays
# fully open (the public-judge / preview / CI path). Set BOTH GitHub vars to
# turn on gating. Callback URL (already registered):
#   https://h0-archon.vercel.app/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Session-signing secret. REQUIRED when auth is enabled. Generate with:
#   openssl rand -base64 32   (or: npx auth secret)
AUTH_SECRET=
# Trust the deployment Host header (Vercel/proxy). Set to true in production.
AUTH_TRUST_HOST=true
